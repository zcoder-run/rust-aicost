# Before All

```lua
local p_utils = require("pricing_utils")

local inputs = p_utils.load_inputs()

aip.run.set_label("gen-json")
aip.agent.run("gen-json.aip", { inputs = inputs })

aip.run.set_label("gen-rs")
aip.agent.run("gen-rs.aip", { inputs = inputs })

return aip.flow.before_all_response({
    inputs = {}
})
```
